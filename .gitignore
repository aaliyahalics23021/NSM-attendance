# Dependency directories (these are installed fresh on Render)
node_modules/
**/node_modules/

# Production build outputs (these are built automatically on Render)
dist/
**/dist/
build/
**/build/

# Environment files containing secret keys (Do NOT commit these to GitHub)
.env
**/.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs and system files
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/
