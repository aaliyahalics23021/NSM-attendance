datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Company {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  logo          String?
  address       String?
  latitude      Float
  longitude     Float
  allowedRadius Float        @default(100.0) // In meters
  timezone      String       @default("Asia/Kolkata")
  currency      String       @default("INR")
  users         User[]
  departments   Department[]
  shifts        Shift[]
  leaves        Leave[]
  holidays      Holiday[]
  salaryRules   SalaryRule[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model User {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  email         String?        @unique
  phone         String?        @unique
  passwordHash  String?
  role          String         @default("EMPLOYEE") // SUPERADMIN, ADMIN, EMPLOYEE
  otpCode       String?
  otpExpiresAt  DateTime?
  companyId     String         @db.ObjectId
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee      Employee?
  auditLogs     AuditLog[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Employee {
  id                 String          @id @default(auto()) @map("_id") @db.ObjectId
  userId             String          @unique @db.ObjectId
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId         String          @unique
  firstName          String
  lastName           String
  departmentId       String          @db.ObjectId
  department         Department      @relation(fields: [departmentId], references: [id])
  shiftId            String          @db.ObjectId
  shift              Shift           @relation(fields: [shiftId], references: [id])
  basicSalary        Float           @default(0.0)
  leaveBalanceCasual Float           @default(12.0)
  leaveBalanceSick   Float           @default(12.0)
  leaveBalancePaid   Float           @default(15.0)
  active             Boolean         @default(true)
  joinedDate         DateTime        @default(now())
  attendance         Attendance[]
  leaves             Leave[]
  payroll            Payroll[]
  faceEmbeddings     FaceEmbedding[]
  gpsLogs            GPSLog[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Department {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  companyId String     @db.ObjectId
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
  holidays  Holiday[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Shift {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  startTime        String     @default("09:00") // "HH:MM"
  endTime          String     @default("18:00") // "HH:MM"
  gracePeriod      Int        @default(15) // minutes
  lateAfter        Int        @default(30) // minutes
  halfDayAfter     Int        @default(120) // minutes (late threshold for halfday)
  absentAfter      Int        @default(240) // minutes (late threshold for absent)
  minWorkHours     Float      @default(8.0) // minimum hours for full day
  maxWorkHours     Float      @default(12.0)
  overtimeAfter    Float      @default(9.0) // hours after which overtime starts
  autoPunchOutTime String     @default("22:00") // "HH:MM"
  companyId        String     @db.ObjectId
  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees        Employee[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Attendance {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  employeeId        String    @db.ObjectId
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date              DateTime // Day without time
  punchInTime       DateTime?
  punchOutTime      DateTime?
  punchInSelfie     String? // Base64 or image path
  punchOutSelfie    String? // Base64 or image path
  punchInLatitude   Float?
  punchInLongitude  Float?
  punchInAccuracy   Float?
  punchInAddress    String?
  punchOutLatitude  Float?
  punchOutLongitude Float?
  punchOutAccuracy  Float?
  punchOutAddress   String?
  status            String    @default("ABSENT") // PRESENT, LATE, HALFDAY, ABSENT, HOLIDAY, ON_LEAVE
  workHours         Float     @default(0.0)
  breakHours        Float     @default(0.0)
  overtimeHours     Float     @default(0.0)
  lateMinutes       Int       @default(0)
  salaryEarnedToday Float     @default(0.0)
  verifiedGPS       Boolean   @default(false)
  verifiedFace      Boolean   @default(false)
  notes             String?
  deviceId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([employeeId, date])
}

model Leave {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String   @db.ObjectId
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  String // CASUAL, SICK, PAID, UNPAID, WFH, OUTDOOR
  startDate  DateTime
  endDate    DateTime
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason     String
  adminNotes String?
  companyId  String   @db.ObjectId
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Holiday {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  date         DateTime
  type         String      @default("NATIONAL") // NATIONAL, COMPANY, FESTIVAL, EMERGENCY, ONETIME, WEEKLY_OFF
  recurring    Boolean     @default(false)
  description  String?
  companyId    String      @db.ObjectId
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String?     @db.ObjectId
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model SalaryRule {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId            String   @unique @db.ObjectId
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  latePenaltyRate      Float    @default(0.0) // deduction rate per late minute
  halfDayDeductionRate Float    @default(0.5) // basic daily rate deduction multiplier
  absentDeductionRate  Float    @default(1.0) // basic daily rate deduction multiplier
  hourlyRate           Float    @default(0.0) // override for hourly pay if applicable
  overtimeMultiplier   Float    @default(1.5) // multiplier * basic hourly rate
  pfRate               Float    @default(0.12) // Provident Fund rate
  esiRate              Float    @default(0.0075) // Employee State Insurance rate
  taxRate              Float    @default(0.0) // General Income tax rate
  tdsRate              Float    @default(0.0) // Tax Deducted at Source
  bonusAmount          Float    @default(0.0) // default monthly bonus allowance
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Payroll {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId           String   @db.ObjectId
  employee             Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month                Int // 1-12
  year                 Int
  basicSalary          Float
  overtimePay          Float    @default(0.0)
  allowances           Float    @default(0.0)
  latePenaltyDeduction Float    @default(0.0)
  halfDayDeduction     Float    @default(0.0)
  absentDeduction      Float    @default(0.0)
  unpaidLeaveDeduction Float    @default(0.0)
  taxDeduction         Float    @default(0.0)
  pfDeduction          Float    @default(0.0)
  esiDeduction         Float    @default(0.0)
  netSalary            Float
  status               String   @default("DRAFT") // DRAFT, APPROVED, PAID
  exportUrl            String?
  generatedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([employeeId, month, year])
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String
  ipAddress String?
  timestamp DateTime @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("INFO") // INFO, ALERT, SUCCESS
  createdAt DateTime @default(now())
}

model FaceEmbedding {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId     String   @db.ObjectId
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  frontEmbedding String // JSON array string of 128 floats
  leftEmbedding  String? // JSON array string of 128 floats
  rightEmbedding String? // JSON array string of 128 floats
  updatedAt      DateTime @updatedAt
}

model GPSLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId String   @db.ObjectId
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  latitude   Float
  longitude  Float
  accuracy   Float
  timestamp  DateTime @default(now())
  success    Boolean
  reason     String
}
